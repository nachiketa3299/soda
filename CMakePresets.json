{
    "version": 3,
    "configurePresets": [
        {
            "name": "soda-config-base",
            "hidden": true,
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "mneo-base",
            "inherits": "soda-config-base",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "CMAKE_OSX_ARCHITECTURES": "arm64"
            },
            "condition": {
                "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin"
            }
        },
        {
            "name": "mneo-debug",
            "inherits": "mneo-base",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "mneo-release",
            "inherits": "mneo-base",
            "binaryDir": "${sourceDir}/build-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ],
    "buildPresets" : [
        {
            "name": "mneo-debug",
            "configurePreset": "mneo-debug",
            "condition": {
                "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin"
            }
        },
        {
            "name": "mneo-release",
            "configurePreset": "mneo-release",
            "condition": {
                "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin"
            }
        }
    ]
}
